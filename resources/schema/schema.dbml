// cakephp-data — database schema snapshot (DBML)
//
// A merged snapshot of all plugin migrations under config/Migrations/.
// Hand-maintained: update it when you add a migration that changes these tables.
// Paste into https://dbdiagram.io (or any DBML tool) to view/diagram.
// DBML reference: https://dbml.dbdiagram.io/docs
// Need it as a migration or raw SQL? Convert this DBML at https://toolbox.dereuromark.de/dbml
//
// Note: foreign_id is a *polymorphic* reference to your application's records — each
// row in the addresses table may point at a different table — so it is intentionally
// not a real foreign key. It defaults to integer; widen it to bigint or binary(16) for
// biginteger/uuid/binaryuuid primary keys (controlled by Polymorphic.type config).

Project cakephp_data {
  database_type: 'Generic'
  Note: 'Reference data tables: geo hierarchy, addresses, currencies, languages, timezones, MIME types.'
}

Table continents {
  id integer [pk, increment]
  name varchar(64) [not null]
  ori_name varchar(64) [not null]
  code varchar(2) [null]
  parent_id int [null]
  lft int [null]
  rght int [null]
  status tinyint [not null, default: 0]
  modified datetime [not null]
}

Table countries {
  id integer [pk, increment]
  name varchar(64) [not null]
  ori_name varchar(64) [not null]
  continent_id int [null]
  iso2 varchar(2) [not null]
  iso3 varchar(3) [not null]
  phone_code varchar(20) [null]
  eu_member boolean [not null, default: false, note: 'Member of the EU']
  zip_length tinyint [not null, default: 0, note: 'if > 0 validate on this length']
  zip_regexp varchar(190) [null]
  sort int [not null, default: 0]
  lat float [null, note: 'latitude']
  lng float [null, note: 'longitude']
  address_format varchar(190) [null]
  timezone_offset varchar(255) [null]
  status tinyint [not null, default: 0]
  modified datetime [not null]

  indexes {
    iso2 [unique]
    iso3 [unique]
  }
}

Table states {
  id integer [pk, increment]
  country_id int [not null]
  code varchar(6) [not null]
  name varchar(60) [not null]
  ori_name varchar(60) [null]
  lat float [null]
  lng float [null]
  modified datetime [not null]
}

Table cities {
  id integer [pk, increment]
  country_id int [not null]
  official_key varchar(10) [not null]
  county_id varchar(8) [not null]
  name varchar(190) [not null, default: '']
  citizens int [null]
  postal_code varchar(7) [not null, default: '']
  lat float [null]
  lng float [null]
  slug varchar(190) [not null, default: '']
  description text [null]
  postal_code_unique boolean [not null, default: false]
  modified datetime [not null]

  indexes {
    slug [unique]
    official_key
    name
    postal_code
  }
}

Table postal_codes {
  id integer [pk, increment]
  country_id int [not null]
  name varchar(10) [not null]
  formatted_address varchar(190) [null]
  lat float [null]
  lng float [null]
  created datetime [not null]
  modified datetime [not null]
}

Table addresses {
  id integer [pk, increment]
  country_id int [not null]
  state_id int [null]
  postal_code varchar(10) [not null]
  city varchar(80) [not null]
  street varchar(80) [not null]
  foreign_id int [null, note: 'Polymorphic foreign id; set Polymorphic.type to biginteger/uuid/binaryuuid to change']
  model_key varchar(60) [null, default: '']
  formatted_address varchar(190) [not null]
  lat float [null]
  lng float [null]
  last_used datetime [null]
  created datetime [not null]
  modified datetime [not null]
}

Table currencies {
  id integer [pk, increment]
  name varchar(190) [not null]
  code char(3) [not null]
  symbol_left varchar(12) [null]
  symbol_right varchar(12) [null]
  decimal_places char(1) [null]
  value decimal(10,4) [null]
  base boolean [not null, default: false, note: 'is base currency']
  active boolean [not null, default: false]
  modified datetime [not null]
}

Table languages {
  id integer [pk, increment]
  name varchar(60) [not null]
  ori_name varchar(60) [not null]
  code varchar(6) [not null]
  iso3 char(3) [not null]
  iso2 char(2) [not null]
  locale varchar(30) [not null]
  locale_fallback varchar(30) [not null]
  status tinyint [not null, default: 0]
  direction tinyint [not null, default: 0]
  sort int [not null, default: 0]
  modified datetime [not null]

  indexes {
    iso2 [unique]
    iso3 [unique]
  }
}

Table timezones {
  id integer [pk, increment]
  name varchar(100) [not null]
  offset int [not null]
  offset_dst int [not null]
  type varchar(100) [not null]
  country_code varchar(2) [null, note: 'ISO_3166-2']
  active boolean [not null, default: false]
  lat float [null]
  lng float [null]
  covered varchar(190) [null]
  notes varchar(190) [null]
  linked_id int [null]
  created datetime [not null]
  modified datetime [not null]
}

Table mime_type_images {
  id integer [pk, increment]
  name varchar(100) [not null, note: 'extension (e.g. jpg)']
  ext varchar(20) [not null, note: 'extension (lowercase!) of real image (exe.gif -> gif)']
  active boolean [not null, default: false]
  details varchar(190) [not null]
  created datetime [not null]
  modified datetime [not null]
}

Table mime_types {
  id integer [pk, increment]
  name varchar(100) [not null, note: 'Program Name']
  ext varchar(20) [not null, note: 'extension (lowercase!)']
  type varchar(190) [not null]
  alt_type varchar(190) [not null, note: 'alternate (sometimes there is more than one type)']
  details varchar(190) [not null]
  core boolean [not null, default: false, note: 'if part of core definitions']
  active boolean [not null, default: false]
  created datetime [not null]
  modified datetime [not null]
  sort int [not null, default: 0, note: 'often used ones should be on top']
  mime_type_image_id int [null]
}

Ref: countries.continent_id > continents.id
Ref: states.country_id > countries.id
Ref: cities.country_id > countries.id
Ref: postal_codes.country_id > countries.id
Ref: addresses.country_id > countries.id
Ref: addresses.state_id > states.id
Ref: mime_types.mime_type_image_id > mime_type_images.id
